{
  "name": "domain-ops",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "railway:start": "node server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "test:e2e:install": "playwright install chromium",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "railway:predeploy": "node scripts/railway-predeploy.mjs",
    "db:status": "prisma migrate status",
    "db:validate": "node scripts/doctor-db.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "worker": "tsx src/worker/index.ts",
    "scheduler": "tsx src/scheduler/index.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "doctor:registry": "node scripts/doctor-registry.mjs",
    "doctor:db": "node scripts/doctor-db.mjs",
    "doctor:auth": "node scripts/doctor-auth.mjs",
    "perf:budget": "node scripts/check-performance-budget.mjs",
    "perf:queries": "node scripts/profile-queries.mjs",
    "smoke:production": "node scripts/production-smoke.mjs",
    "supply-chain:check": "node scripts/check-supply-chain.mjs",
    "security:audit": "node scripts/check-vulnerabilities.mjs",
    "security:sbom": "npm sbom --sbom-format cyclonedx"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@prisma/client": "6.19.3",
    "@tanstack/react-table": "8.21.3",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "next-auth": "4.24.14",
    "otpauth": "9.5.1",
    "papaparse": "5.5.4",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "recharts": "3.9.2",
    "redis": "5.12.1",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.18",
    "prisma": "7.8.0",
    "tailwindcss": "3.4.19",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "packageManager": "npm@11.4.2",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22 <25",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11 <12",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=22 <25",
    "npm": ">=11 <12"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
