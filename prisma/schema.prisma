generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum Status {
  ACTIVE
  INACTIVE
  PENDING
  ARCHIVED
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  PROHIBITED
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id                        String                   @id @default(cuid())
  email                     String                   @unique
  name                      String?
  passwordHash              String?
  emailVerified             DateTime?
  mfaEnabledAt              DateTime?
  mfaSecretEncrypted        String?
  mfaPendingSecretEncrypted String?
  role                      Role                     @default(MEMBER)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  memberships               WorkspaceMember[]
  accounts                  Account[]
  sessions                  Session[]
  createdDomains            Domain[]
  sentInvitations           WorkspaceInvitation[]    @relation("InvitationSender")
  passwordResets            PasswordResetToken[]
  emailVerifications        EmailVerificationToken[]
  mfaRecoveryCodes          MfaRecoveryCode[]
  authSessions              AuthSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt])
}

model EmailVerificationToken {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt])
  @@index([workspaceId, createdAt])
}

model MfaRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model AuthSession {
  id                 String    @id
  userId             String
  provider           String
  createdAt          DateTime  @default(now())
  lastSeenAt         DateTime  @default(now())
  expiresAt          DateTime
  mfaAuthenticatedAt DateTime?
  stepUpAt           DateTime?
  revokedAt          DateTime?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
}

model Workspace {
  id                      String                   @id @default(cuid())
  name                    String
  slug                    String                   @unique
  status                  Status                   @default(ACTIVE)
  metadata                Json                     @default("{}")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  members                 WorkspaceMember[]
  domains                 Domain[]
  watchlists              Watchlist[]
  portfolio               PortfolioItem[]
  jobs                    BackgroundJob[]
  invitations             WorkspaceInvitation[]
  subscriptions           Subscription[]
  billingEvents           BillingEvent[]
  emailVerificationTokens EmailVerificationToken[]
  operationalEvents       OperationalEvent[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        Role      @default(MEMBER)
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model WorkspaceInvitation {
  id          String    @id @default(cuid())
  workspaceId String
  invitedById String
  email       String
  role        Role      @default(MEMBER)
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId, email, acceptedAt, revokedAt])
}

model Plan {
  id            String               @id @default(cuid())
  name          String               @unique
  priceCents    Int
  entitlements  FeatureEntitlement[]
  subscriptions Subscription[]
}

model Subscription {
  id                     String    @id @default(cuid())
  workspaceId            String
  planId                 String
  status                 String
  provider               String    @default("MANUAL")
  externalCustomerId     String?
  externalSubscriptionId String?   @unique
  trialEndsAt            DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  plan                   Plan      @relation(fields: [planId], references: [id])
  workspace              Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, createdAt])
  @@index([externalCustomerId])
}

model BillingEvent {
  id              String    @id @default(cuid())
  workspaceId     String
  provider        String
  providerEventId String    @unique
  type            String
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model FeatureEntitlement {
  id      String  @id @default(cuid())
  planId  String
  key     String
  limit   Int?
  enabled Boolean @default(true)
  plan    Plan    @relation(fields: [planId], references: [id])

  @@unique([planId, key])
}

model UsageRecord {
  id          String   @id @default(cuid())
  workspaceId String
  key         String
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())

  @@index([workspaceId, key, createdAt])
}

model Domain {
  id              String               @id @default(cuid())
  workspaceId     String
  createdById     String
  name            String
  tld             String
  status          Status               @default(ACTIVE)
  source          String
  metadata        Json                 @default("{}")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User                 @relation(fields: [createdById], references: [id])
  checks          DomainCheck[]
  opportunity     DomainOpportunity?
  scores          DomainScore[]
  valuations      Valuation[]
  trademarkChecks TrademarkCheck[]
  historyChecks   DomainHistoryCheck[]
  watchlistItems  WatchlistItem[]
  portfolioItems  PortfolioItem[]
  buyers          Buyer[]
  offers          Offer[]
  sales           Sale[]
  renewals        Renewal[]

  @@unique([workspaceId, name])
  @@index([workspaceId, status])
}

model DomainCheck {
  id                String   @id @default(cuid())
  domainId          String
  available         Boolean
  registrationPrice Decimal
  renewalPrice      Decimal
  transferPrice     Decimal?
  premium           Boolean  @default(false)
  registrar         String
  status            String
  checkedAt         DateTime @default(now())
  domain            Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

model DomainOpportunity {
  id                 String    @id @default(cuid())
  workspaceId        String
  domainId           String
  score              Int
  riskLevel          RiskLevel
  estimatedRetailMin Decimal
  estimatedRetailMax Decimal
  buyerCount         Int
  status             Status    @default(ACTIVE)
  notes              String?
  approvalStatus     String    @default("PENDING")
  approvedAt         DateTime?
  approvedById       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  domain             Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([domainId])
  @@index([workspaceId, score])
}

model DomainScore {
  id        String        @id @default(cuid())
  domainId  String
  total     Int
  summary   String
  createdAt DateTime      @default(now())
  domain    Domain        @relation(fields: [domainId], references: [id], onDelete: Cascade)
  factors   ScoreFactor[]
}

model ScoreFactor {
  id          String      @id @default(cuid())
  scoreId     String
  name        String
  value       Int
  maxValue    Int
  explanation String
  score       DomainScore @relation(fields: [scoreId], references: [id], onDelete: Cascade)
}

model Valuation {
  id             String   @id @default(cuid())
  domainId       String
  wholesale      Decimal
  retailMin      Decimal
  retailMax      Decimal
  buyNow         Decimal
  minOffer       Decimal
  maxAcquisition Decimal
  confidence     String
  explanation    String
  createdAt      DateTime @default(now())
  domain         Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

model ComparableSale {
  id            String   @id @default(cuid())
  workspaceId   String
  createdById   String?
  subjectDomain String
  domain        String
  tld           String
  price         Decimal
  saleDate      DateTime
  marketplace   String
  industry      String?
  source        String   @default("MANUAL")
  evidenceUrl   String?
  checkedAt     DateTime @default(now())
  createdAt     DateTime @default(now())
  metadata      Json     @default("{}")

  @@unique([workspaceId, subjectDomain, domain, price, saleDate])
  @@index([workspaceId, subjectDomain, saleDate])
}

model ComparableSaleImportBatch {
  id            String    @id @default(cuid())
  workspaceId   String
  createdById   String
  filename      String
  status        String    @default("REVIEW")
  totalRows     Int
  validRows     Int
  duplicateRows Int
  errorRows     Int
  rows          Json
  importedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([workspaceId, status, createdAt])
}

model ProviderCache {
  id          String   @id @default(cuid())
  workspaceId String
  provider    String
  cacheKey    String
  payload     Json
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime
  staleAt     DateTime

  @@unique([workspaceId, provider, cacheKey])
  @@index([workspaceId, provider, expiresAt])
}

model ProviderUsage {
  id            String    @id @default(cuid())
  workspaceId   String
  provider      String
  periodStart   DateTime
  requestCount  Int       @default(0)
  cacheHits     Int       @default(0)
  failures      Int       @default(0)
  lastRequestAt DateTime?
  updatedAt     DateTime  @updatedAt

  @@unique([workspaceId, provider, periodStart])
  @@index([workspaceId, periodStart])
}

model ResearchConsent {
  id            String    @id @default(cuid())
  workspaceId   String
  provider      String
  acceptedById  String
  policyVersion String
  acceptedAt    DateTime  @default(now())
  revokedAt     DateTime?

  @@unique([workspaceId, provider, policyVersion])
  @@index([workspaceId, provider, revokedAt])
}

model PublicBusinessEvidence {
  id            String   @id @default(cuid())
  workspaceId   String
  subjectDomain String
  provider      String
  companyName   String
  jurisdiction  String?
  identifier    String?
  sourceUrl     String
  fetchedAt     DateTime
  stale         Boolean  @default(false)
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())

  @@unique([workspaceId, subjectDomain, provider, companyName, sourceUrl])
  @@index([workspaceId, subjectDomain, fetchedAt])
}

model TrademarkCheck {
  id         String    @id @default(cuid())
  domainId   String
  riskLevel  RiskLevel
  matches    Json      @default("[]")
  disclaimer String
  reviewedBy String?
  createdAt  DateTime  @default(now())
  domain     Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

model DomainHistoryCheck {
  id        String    @id @default(cuid())
  domainId  String
  riskLevel RiskLevel
  flags     Json      @default("[]")
  evidence  Json      @default("[]")
  checkedAt DateTime  @default(now())
  domain    Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

model DiscoveryJob {
  id            String    @id @default(cuid())
  workspaceId   String
  createdById   String
  status        JobStatus @default(QUEUED)
  source        String
  savedSearchId String?
  criteria      Json
  progress      Int       @default(0)
  resultCount   Int       @default(0)
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([workspaceId, status, createdAt])
  @@index([savedSearchId, createdAt])
}

model DiscoverySource {
  id      String  @id @default(cuid())
  name    String
  type    String
  enabled Boolean @default(true)
  config  Json    @default("{}")

  @@unique([name, type])
}

model SavedSearch {
  id          String    @id @default(cuid())
  workspaceId String
  createdById String
  name        String
  source      String
  schedule    String
  criteria    Json
  status      Status    @default(ACTIVE)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, status, nextRunAt])
}

model ImportBatch {
  id            String    @id @default(cuid())
  workspaceId   String
  createdById   String
  filename      String
  industry      String
  status        String    @default("REVIEW")
  totalRows     Int
  validRows     Int
  duplicateRows Int
  errorRows     Int
  rows          Json
  importedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([workspaceId, status, createdAt])
}

model Watchlist {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  notes       String?
  status      Status          @default(ACTIVE)
  createdAt   DateTime        @default(now())
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items       WatchlistItem[]
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  domainId    String
  notes       String?
  tags        String[]
  createdAt   DateTime  @default(now())
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  domain      Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, domainId])
}

model PortfolioItem {
  id               String    @id @default(cuid())
  workspaceId      String
  domainId         String
  registrar        String
  purchaseDate     DateTime
  purchaseCost     Decimal
  renewalCost      Decimal
  expirationDate   DateTime
  autoRenew        Boolean   @default(false)
  currentValuation Decimal
  buyNowPrice      Decimal?
  minSalePrice     Decimal?
  purchaseSource   String?
  nameservers      String[]  @default([])
  notes            String?
  category         String?
  tags             String[]  @default([])
  status           Status    @default(ACTIVE)
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  domain           Domain    @relation(fields: [domainId], references: [id])

  @@index([workspaceId, status, expirationDate])
  @@index([workspaceId, domainId])
}

model RegistrarAccount {
  id                   String @id @default(cuid())
  workspaceId          String
  provider             String
  encryptedCredentials String
  status               Status @default(ACTIVE)
}

model MarketplaceListing {
  id          String  @id @default(cuid())
  workspaceId String
  domainId    String
  marketplace String
  price       Decimal
  status      String
}

model Buyer {
  id             String         @id @default(cuid())
  workspaceId    String
  domainId       String
  companyName    String
  website        String?
  industry       String
  location       String?
  reasonForFit   String
  relevanceScore Int
  outreachStatus String
  domain         Domain         @relation(fields: [domainId], references: [id])
  contacts       BuyerContact[]
}

model BuyerContact {
  id          String  @id @default(cuid())
  buyerId     String
  name        String?
  title       String?
  email       String?
  phone       String?
  linkedinUrl String?
  buyer       Buyer   @relation(fields: [buyerId], references: [id], onDelete: Cascade)
}

model OutreachCampaign {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  status      Status @default(ACTIVE)
}

model OutreachMessage {
  id          String    @id @default(cuid())
  workspaceId String
  campaignId  String?
  subject     String
  body        String
  status      String
  approvedAt  DateTime?
}

model Offer {
  id          String    @id @default(cuid())
  workspaceId String
  domainId    String
  amount      Decimal
  status      String
  buyerName   String?
  buyerEmail  String?
  notes       String?
  createdAt   DateTime  @default(now())
  respondedAt DateTime?
  updatedAt   DateTime  @updatedAt
  domain      Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, createdAt])
  @@index([domainId])
}

model Sale {
  id          String   @id @default(cuid())
  workspaceId String
  domainId    String
  salePrice   Decimal
  fees        Decimal
  netProfit   Decimal
  saleDate    DateTime
  source      String?
  notes       String?
  createdAt   DateTime @default(now())
  domain      Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([workspaceId, saleDate])
  @@index([domainId])
}

model Renewal {
  id             String    @id @default(cuid())
  workspaceId    String
  domainId       String
  dueDate        DateTime
  cost           Decimal
  recommendation String
  status         String
  decision       String?
  notes          String?
  decidedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  domain         Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, domainId, dueDate])
  @@index([workspaceId, status, dueDate])
}

model Notification {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  title       String
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Report {
  id          String   @id @default(cuid())
  workspaceId String
  type        String
  title       String
  payload     Json
  createdAt   DateTime @default(now())
}

model Integration {
  id          String @id @default(cuid())
  workspaceId String
  provider    String
  status      Status @default(ACTIVE)
  config      Json   @default("{}")
}

model ApiCredential {
  id              String   @id @default(cuid())
  workspaceId     String
  provider        String
  encryptedSecret String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([workspaceId, provider])
}

model BackgroundJob {
  id            String    @id @default(cuid())
  workspaceId   String
  type          String
  status        JobStatus @default(QUEUED)
  progress      Int       @default(0)
  attempts      Int       @default(0)
  error         String?
  payload       Json      @default("{}")
  lockedAt      DateTime?
  lockedBy      String?
  lockExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status, lockExpiresAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String?
  actorId     String?
  action      String
  targetType  String
  targetId    String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
}

model AiUsage {
  id               String   @id @default(cuid())
  workspaceId      String
  userId           String?
  model            String
  promptTokens     Int
  completionTokens Int
  costCents        Int
  prompt           String
  output           String
  createdAt        DateTime @default(now())
}

model Webhook {
  id          String @id @default(cuid())
  workspaceId String
  url         String
  secretHash  String
  status      Status @default(ACTIVE)
}

model FeatureFlag {
  id          String  @id @default(cuid())
  key         String  @unique
  enabled     Boolean @default(false)
  description String?
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model OperationalEvent {
  id            String     @id @default(cuid())
  workspaceId   String?
  source        String
  level         String
  outcome       String
  event         String
  message       String
  correlationId String?
  durationMs    Int?
  metadata      Json       @default("{}")
  occurredAt    DateTime   @default(now())
  resolvedAt    DateTime?
  alertedAt     DateTime?
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, occurredAt])
  @@index([source, outcome, occurredAt])
  @@index([workspaceId, resolvedAt, occurredAt])
}
